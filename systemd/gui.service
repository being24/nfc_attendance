[Unit]
Description=NFC Attendance Web App
After=network.target

[Service]
Type=simple
User=being
WorkingDirectory=/home/being/programs/nfc_attendance
EnvironmentFile=/home/being/programs/nfc_attendance/.env
ExecStart=/home/being/.local/bin/uv run python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
